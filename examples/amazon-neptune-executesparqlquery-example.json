      }
    },
    {
      "contentType": "application/x-www-form-urlencoded",
      "name": "insertData",
      "example": {
        "update": "INSERT DATA { <https://example.org/s> <https://example.org/p> <https://example.org/o> . }"
      }
    }
  ],
  "responseExamples": [
    {
      "status": "400",
      "contentType": "application/json",
