{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-neptune/refs/heads/main/json-schema/data-gremlin-query-status-schema.json",
  "title": "GremlinQueryStatus",
  "description": "GremlinQueryStatus schema from Neptune",
  "type": "object",
  "properties": {
    "queryId": {
      "type": "string"
    },
    "queryString": {
      "type": "string"
    },
    "queryEvalStats": {
      "type": "object",
      "properties": {
        "waited": {
          "type": "integer"
        },
        "elapsed": {
          "type": "integer"
        },
        "cancelled": {
          "type": "boolean"
        }
      }
    }
  }
}