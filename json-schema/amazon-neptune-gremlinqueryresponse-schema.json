{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/GremlinQueryResponse",
  "title": "GremlinQueryResponse",
  "type": "object",
  "properties": {
    "requestId": {
      "type": "string",
      "format": "uuid",
      "description": "The unique request identifier."
    },
    "status": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string"
        },
        "code": {
          "type": "integer",
          "description": "The response status code (200 for success)."
        },
        "attributes": {
          "type": "object",
          "description": "Additional response attributes."
        }
      }
    },
    "result": {
      "type": "object",
      "properties": {
        "data": {
          "description": "The query result data. The shape depends on the traversal's terminal step (e.g., count, valueMap, path)."
        },
        "meta": {
          "type": "object"
        }
      }
    }
  }
}