{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ModifyDBInstanceRequest",
  "title": "ModifyDBInstanceRequest",
  "type": "object",
  "required": [
    "DBInstanceIdentifier"
  ],
  "properties": {
    "DBInstanceIdentifier": {
      "type": "string",
