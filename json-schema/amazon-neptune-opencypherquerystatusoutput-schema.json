{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/OpenCypherQueryStatusOutput",
  "title": "OpenCypherQueryStatusOutput",
  "type": "object",
  "properties": {
    "acceptedQueryCount": {
      "type": "integer"
    },
    "runningQueryCount": {
      "type": "integer"
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "queryId": {
            "type": "string"
          },
          "queryString": {
            "type": "string"
          },
          "queryEvalStats": {
            "type": "object"
          }
        }
      }
    }
  }
}