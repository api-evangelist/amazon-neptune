        {
          "id": "e2985c65-bc98-4f42-ae9c-7356badf9449",
          "name": "Amazon Neptune Start a Bulk Data Load Job from S3",
          "request": {
            "name": "Amazon Neptune Start a Bulk Data Load Job from S3",
            "description": {
              "content": "Initiates a bulk data loading job from Amazon S3 into the Neptune database. The source data can be in CSV format for property graphs or in N-Triples, N-Quads, RDF/XML, or Turtle formats for RDF data. The loader requires an IAM role with access to the S3 bucket. Neptune queues up to 64 jobs in FIFO order when queueRequest is enabled.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "loader"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "description": "The cluster endpoint DNS name for your Neptune DB cluster",
                  "type": "any",
                  "value": "{{cluster-endpoint}}",
                  "key": "cluster-endpoint"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"<string>\",\n  \"format\": \"<string>\",\n  \"iamRoleArn\": \"<string>\",\n  \"region\": \"<string>\",\n  \"mode\": \"AUTO\",\n  \"failOnError\": \"TRUE\",\n  \"parallelism\": \"HIGH\",\n  \"parserConfiguration\": {\n    \"baseUri\": \"<string>\",\n    \"namedGraphUri\": \"<string>\",\n    \"allowEmptyStrings\": \"<boolean>\"\n  },\n  \"updateSingleCardinalityProperties\": \"FALSE\",\n  \"queueRequest\": \"FALSE\",\n  \"dependencies\": [\n    \"<string>\",\n    \"<string>\"\n  ],\n  \"userProvidedEdgeIds\": \"<string>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "0205b0e0-ec83-4d0d-b6c2-93412b1b2a83",
              "name": "Bulk load job started successfully.",
