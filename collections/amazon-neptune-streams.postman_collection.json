      "item": [
        {
          "id": "5d3e7c10-6252-453e-83ce-d5b2dd5b7d3e",
          "name": "Amazon Neptune Get Property Graph Change Stream Records",
          "request": {
            "name": "Amazon Neptune Get Property Graph Change Stream Records",
            "description": {
              "content": "Gets a stream of change-log entries for property graph (Gremlin/openCypher) data. Each entry records a mutation (ADD or REMOVE) made to vertices, edges, or their properties. The response format is PG_JSON. This is the recommended endpoint for property graph streams, replacing the deprecated /gremlin/stream endpoint.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "propertygraph",
                "stream"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "limit",
                  "value": "10",
                  "description": "Maximum number of records to return (1-100,000). Default is 10. The 10 MB response size limit takes precedence over this value."
                },
                {
                  "disabled": false,
                  "key": "iteratorType",
                  "value": "AT_SEQUENCE_NUMBER",
                  "description": "Determines the starting point for reading the stream."
                },
                {
                  "disabled": false,
                  "key": "commitNum",
                  "value": "<integer>",
                  "description": "The commit number to start reading from. Required when iteratorType is AT_SEQUENCE_NUMBER or AFTER_SEQUENCE_NUMBER."
                },
                {
                  "disabled": false,
                  "key": "opNum",
                  "value": "1",
                  "description": "The operation sequence number within the specified commit. Default is 1."
                }
              ],
              "variable": [
                {
                  "description": "The cluster endpoint DNS name for your Neptune DB cluster",
                  "type": "any",
                  "value": "{{cluster-endpoint}}",
                  "key": "cluster-endpoint"
                }
              ]
            },
            "header": [
              {
                "disabled": false,
                "description": "Set to 'gzip' to receive compressed responses.",
                "key": "Accept-Encoding",
                "value": "<string>"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
