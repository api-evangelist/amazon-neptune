              ],
              "body": "{\n  \"head\": {\n    \"vars\": [\n      \"string\",\n      \"string\"\n    ],\n    \"link\": [\n      \"string\",\n      \"string\"\n    ]\n  },\n  \"results\": {\n    \"bindings\": [\n      {\n        \"key_0\": {\n          \"type\": \"bnode\",\n          \"value\": \"string\",\n          \"datatype\": \"string\",\n          \"xml:lang\": \"string\"\n        }\n      },\n      {\n        \"key_0\": {\n          \"type\": \"bnode\",\n          \"value\": \"string\",\n          \"datatype\": \"string\",\n          \"xml:lang\": \"string\"\n        },\n        \"key_1\": {\n          \"type\": \"uri\",\n          \"value\": \"string\",\n          \"datatype\": \"string\",\n          \"xml:lang\": \"string\"\n        }\n      }\n    ]\n  },\n  \"boolean\": true\n}",
