          "name": "Amazon Neptune Execute a SPARQL Query or Update via HTTP POST",
          "request": {
            "name": "Amazon Neptune Execute a SPARQL Query or Update via HTTP POST",
            "description": {
              "content": "Submits a SPARQL 1.1 query or update operation to the Neptune SPARQL endpoint. For queries, use the 'query' parameter with SELECT, ASK, CONSTRUCT, or DESCRIBE forms. For mutations, use the 'update' parameter with INSERT DATA or DELETE DATA operations. The request body is form-encoded per the SPARQL 1.1 Protocol specification.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "sparql"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "description": "The cluster endpoint DNS name for your Neptune DB cluster",
                  "type": "any",
                  "value": "{{cluster-endpoint}}",
                  "key": "cluster-endpoint"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "Accept",
                "value": "application/sparql-results+json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "disabled": false,
                  "key": "query",
                  "value": "<string>",
                  "description": "A SPARQL 1.1 query (SELECT, ASK, CONSTRUCT, or DESCRIBE). Mutually exclusive with update."
                },
                {
                  "disabled": false,
                  "key": "update",
                  "value": "<string>",
                  "description": "A SPARQL 1.1 Update operation (INSERT DATA, DELETE DATA, etc.). Mutually exclusive with query."
                },
                {
                  "disabled": false,
                  "key": "using-graph-uri",
                  "value": "<string>",
                  "description": "Default graph URI for the query."
                },
                {
                  "disabled": false,
                  "key": "using-named-graph-uri",
                  "value": "<string>",
                  "description": "Named graph URI for the query."
                }
              ]
            }
          },
          "response": [
            {
              "id": "2a69558f-47de-4f2a-8993-e03ebcb60103",
              "name": "SPARQL query or update executed successfully.",
              "originalRequest": {
                "url": {
                  "path": [
                    "sparql"
                  ],
                  "host": [
                    "{{baseUrl}}"
