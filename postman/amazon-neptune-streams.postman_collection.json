                    "value": "gzip"
                  },
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/propertygraph/stream?limit=10&iteratorType=AT_SEQUENCE_NUMBER&commitNum=<integer>&opNum=1",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "propertygraph",
                    "stream"
                  ],
                  "query": [
                    {
                      "description": "Maximum number of records to return (1-100,000). Default is 10. The 10 MB response size limit takes precedence over this value.",
                      "key": "limit",
                      "value": "10"
                    },
                    {
                      "description": "Determines the starting point for reading the stream.",
                      "key": "iteratorType",
                      "value": "AT_SEQUENCE_NUMBER"
                    },
                    {
                      "description": "The commit number to start reading from. Required when iteratorType is AT_SEQUENCE_NUMBER or AFTER_SEQUENCE_NUMBER.",
                      "key": "commitNum",
                      "value": "<integer>"
                    },
                    {
                      "description": "The operation sequence number within the specified commit. Default is 1.",
                      "key": "opNum",
                      "value": "1"
                    }
                  ]
                },
                "description": "Gets a stream of change-log entries for property graph (Gremlin/openCypher) data. Each entry records a mutation (ADD or REMOVE) made to vertices, edges, or their properties. The response format is PG_JSON. This is the recommended endpoint for property graph streams, replacing the deprecated /gremlin/stream endpoint."
