              "protocolProfileBehavior": {
                "disableBodyPruning": true
              },
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/loader/:loadId?details=<boolean>&errors=<boolean>&page=<integer>&errorsPerPage=<integer>",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "loader",
                    ":loadId"
                  ],
                  "query": [
                    {
                      "description": "Whether to include detailed feed-level status information.",
                      "key": "details",
                      "value": "<boolean>"
                    },
                    {
                      "description": "Whether to include error details in the response.",
                      "key": "errors",
                      "value": "<boolean>"
                    },
                    {
                      "description": "The error page number to retrieve (when errors=true).",
                      "key": "page",
                      "value": "<integer>"
                    },
                    {
                      "description": "The number of errors per page (when errors=true).",
                      "key": "errorsPerPage",
                      "value": "<integer>"
                    }
                  ],
                  "variable": [
                    {
                      "id": "90e057c4-376d-4a62-af70-b048d924531e",
                      "key": "loadId",
                      "value": "<string>",
                      "description": "(Required) The unique identifier of the bulk load job."
                    }
                  ]
                },
                "description": "Returns the status of a specific bulk load job by its load ID. Includes overall status, feed counts, and optionally detailed error information. Neptune stores the last 10,000 error details per job."
