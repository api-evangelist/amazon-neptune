        {
          "name": "Amazon Neptune Start a Bulk Data Load Job from S3",
          "id": "aa3d8512-885b-4ff8-9b7e-5b9baa78bf66",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
